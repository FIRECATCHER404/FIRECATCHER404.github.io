{
  "rules": {
    ".read": false,
    ".write": false,
    "count": {
      ".read": true,
      ".write": true,
      ".validate": "newData.isNumber()"
    },
    "retro": {
      ".read": true,
      ".write": true
    },
    "users": {
      ".read": true,
      ".write": true
    },
    "messages": {
      ".read": true,
      ".write": true
    },
    "groups": {
      ".read": true,
      ".write": true
    },
    "waiting": {
      ".read": true,
      ".write": true
    },
    "games": {
      ".read": true,
      ".write": true
    },
    "posts": {
      ".read": "(query.orderByChild === 'published' && query.equalTo === true) || (auth != null && auth.token.admin === true)",
      ".indexOn": ["published"],
      "$postId": {
        ".read": "data.child('published').val() === true || (auth != null && auth.token.admin === true)",
        ".write": false,
        "likesBy": {
          "$clientId": {
            ".write": "newData.val() === true && !data.exists() && $clientId.matches(/^[A-Za-z0-9_-]{8,128}$/)",
            ".validate": "newData.val() === true"
          }
        },
        "comments": {
          "$commentId": {
            ".write": "auth != null && root.child('posts/' + $postId + '/published').val() === true && !data.exists() && newData.hasChildren(['uid','name','text','createdAt']) && newData.child('uid').val() === auth.uid",
            ".validate": "newData.hasChildren(['uid','name','text','createdAt']) && newData.child('uid').isString() && newData.child('uid').val().matches(/^[A-Za-z0-9:_-]{6,128}$/) && newData.child('name').isString() && newData.child('name').val().matches(/^.{2,32}$/) && newData.child('text').isString() && newData.child('text').val().matches(/^.{2,1000}$/) && newData.child('createdAt').isNumber()"
          }
        }
      }
    }
  }
}
